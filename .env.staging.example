# Entorno de STAGING — apunta al proyecto Supabase de pruebas, NUNCA al de producción.
# Copia este archivo a `.env.staging` y rellena con los datos del proyecto de staging.
#   cp .env.staging.example .env.staging   (o copialo a mano en Windows)
# `.env.staging` está en .gitignore: no se commitea.
#
# Se carga con: npm run dev:staging  (vite --mode staging)

VITE_SUPABASE_URL=https://TU_PROYECTO_STAGING.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_de_staging_aqui

# Bandera para distinguir visualmente staging de producción en la UI.
VITE_APP_ENV=staging
